# Get a free API key from https://www.football-data.org/
# Free tier: 10 calls/min, includes World Cup data
FOOTBALL_DATA_API_KEY=your_api_key_here

# Frontend URL for CORS
FRONTEND_URL=http://localhost:6001

# Server port (default 6173)
PORT=6173

# Alibaba Cloud DashScope API key — used for all Qwen LLM calls
# Get one from: https://dashscope.aliyuncs.com
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Enable multi-agent Qwen prediction system (true/false, default false)
USE_MULTI_AGENT=false
