# API base URL — required in production (Render sets this automatically via render.yaml)
# Leave blank for local dev (Vite proxy handles /api -> localhost:6173)
VITE_API_URL=

# Your production domain — used to build absolute og:url and og:image tags
# e.g. https://wc2026.yourdomain.com  (no trailing slash)
# Leave blank for local dev (OG tags will be omitted when empty)
VITE_SITE_URL=

# Google Search Console verification token (HTML tag method)
# Get this from: Search Console → Add property → HTML tag → copy the content="..." value
# Leave blank to omit the tag
VITE_GSC_VERIFICATION=
